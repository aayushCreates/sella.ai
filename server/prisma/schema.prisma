generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ReportStatus {
  PENDING
  SCRAPING
  ANALYZING
  DONE
  FAILED
}

enum CompetitionLevel {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum MarketMaturity {
  EMERGING
  GROWING
  MATURE
  SATURATED
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  password  String
  firstName String?
  lastName  String?
  avatarUrl String?

  reports Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id       String       @id @default(uuid())
  url      String
  category String
  status   ReportStatus @default(PENDING)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  products Product[]
  analysis Analysis?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id                 String   @id @default(uuid())
  asin               String
  title              String?
  price              Float?
  rating             Float?
  reviewCount        Int?
  bestSellerRank     Int?
  estimatedUnitsSold Int?
  estimatedRevenue   Float?
  bullets            String[]
  imageUrl           String?
  productUrl         String

  reportId String
  report   Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reviews  Review[]

  @@index([reportId])
  @@index([asin])
}

model Review {
  id    String  @id @default(uuid())
  stars Int?
  title String?
  body  String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId])
}

model Analysis {
  id String @id @default(cuid())

  totalMonthlyRevenue Float?
  avgPrice            Float?
  avgRating           Float?
  competitionLevel    CompetitionLevel?
  marketMaturity      MarketMaturity?
  opportunityScore    Int?
  marketSummary       String?

  topCompetitors      Json?
  customerInsights    Json?
  marketGaps          Json?
  hookPatterns        Json?
  entryRecommendation Json?

  reportId String @unique
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
